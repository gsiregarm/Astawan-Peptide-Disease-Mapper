# @title 2A. Alignment Engine (Smith-Waterman)
import pandas as pd
from multiprocessing import Pool, cpu_count
from Bio.Align import PairwiseAligner, substitution_matrices
from tqdm.notebook import tqdm

def worker_align_peptide(seq):
    if not seq: return (seq, "None", 0)

    aligner = PairwiseAligner()
    aligner.mode = 'local'
    aligner.open_gap_score = -10
    aligner.extend_gap_score = -0.5
    try:
        aligner.substitution_matrix = substitution_matrices.load("BLOSUM62")
    except:
        aligner.match_score, aligner.mismatch_score = 5, -4

    best_score, best_gene = 0, "None"

    # Assuming HUMAN_PROTEOME is loaded in your environment
    for gene, prot_seq in HUMAN_PROTEOME.items():
        if not prot_seq: continue
        score = aligner.score(seq, prot_seq)
        if score > best_score:
            best_score, best_gene = score, gene

    if best_score > (len(seq) * 3.5):
        return (seq, best_gene, round(best_score, 2))
    return (seq, "No_Significant_Match", 0)

